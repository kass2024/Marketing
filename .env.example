APP_NAME="Parrot Canada Visa Consultant"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Meta/WhatsApp hub + Parrot forward: tail -f storage/logs/webhook.log
LOG_WEBHOOK_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=
# Production VPS: if MySQL only exposes a socket, use DB_HOST=localhost and optionally:
# DB_SOCKET=/var/run/mysqld/mysqld.sock
# Migrations: composer install / deploy runs `php artisan migrate:auto` automatically.
# Manual: php artisan migrate:auto  (local)  |  php artisan migrate:auto --force  (VPS)
#
# VPS cron (REQUIRED for auto-sync + Meta jobs) — run every minute:
# * * * * * cd /var/www/your-app && php artisan schedule:run >> /dev/null 2>&1
# Deploy: php artisan deploy:safe
# Soft Meta sync throttle (seconds) between page-load syncs:
META_AUTO_SYNC_TTL=120
PLATFORM_CONTROLS_API=true

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

VITE_APP_NAME="${APP_NAME}"

# --- HTTP API (config/services.php) ---
API_TIMEOUT=30
API_RETRY_ATTEMPTS=2

# --- Admin ---
ADMIN_EMAIL=

# --- Inbox / human handoff (config/chat.php); schedule: php artisan schedule:run every minute ---
CHAT_AGENT_PRIORITY=4,5
CHAT_AGENT_TIMEOUT=60
CHAT_BOT_FALLBACK_TIMEOUT=900
CHAT_AGENT_SILENCE_TIMEOUT=
CHAT_NO_AGENT_SESSION_TIMEOUT=300
CHAT_ENABLE_BOT_FALLBACK=true
CHAT_ENABLE_AGENT_REASSIGNMENT=true

# --- OpenAI (config/services.php openai.* — chatbot fallback) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_IMAGE_MODEL=dall-e-3

# --- Google Gemini (Ad Studio AI — primary) ---
# Get key: https://aistudio.google.com/apikey — must start with AIzaSy
GOOGLE_AI_API_KEY=
GOOGLE_AI_MODEL=gemini-2.5-flash
# Invalid/non-API format — do not use; GOOGLE_AI_API_KEY is preferred
# GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.0-flash-preview-image-generation
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Charon
GEMINI_STT_MODEL=gemini-2.5-flash
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT=45
GEMINI_CONNECT_TIMEOUT=15
GEMINI_IMAGE_TIMEOUT=120
GEMINI_MAX_OUTPUT_TOKENS=8192
GEMINI_RETRY_ATTEMPTS=3
GEMINI_RETRY_DELAY_MS=1500

# --- Ad Studio ---
AD_AI_PROVIDER=gemini

# --- Chatbot voice (config/chatbot.php) ---
CHATBOT_TRANSCRIBE_AUDIO=true
CHATBOT_VOICE_FAQ_REPLIES=false

# Tenant businesses never OAuth — each picks Page + WA; API token stays on main account.
PLATFORM_TENANTS_SHARE_META=false
PLATFORM_CONTROLS_API=true

# --- Meta Business (MAIN PLATFORM ACCOUNT ONLY — config/platform.php) ---
# Tenant OAuth connections are stored per-client in the database.
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=
META_SYSTEM_USER_TOKEN=
META_AD_ACCOUNT_ID=
META_PAGE_ID=
META_PAGE_NAME=
META_INSTAGRAM_USER_ID=
META_GRAPH_VERSION=v19.0

# --- WhatsApp (MAIN PLATFORM ACCOUNT ONLY — config/platform.php) ---
# Tenant businesses store their own numbers in platform_meta_connections (DB).
# After editing .env run: php artisan waba:install  OR  Admin → Tenant monitor → Sync
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_BUSINESS_ID=
WHATSAPP_PHONE_NUMBER=
WHATSAPP_REGISTRATION_PIN=123456
WHATSAPP_TIMEOUT=30
FFMPEG_BINARY=ffmpeg

# Parrot WA Support (wa-support-api): same Meta app, forward from /api/webhook/meta
# Comma-separated Graph API phone_number_id values that belong to Parrot, not WABA2.
PARROT_SUPPORT_PHONE_NUMBER_IDS=
# Full URL to Parrot webhook (internal http://127.0.0.1/... OK on same server)
PARROT_WEBHOOK_FORWARD_URL=

# Shown in Platform Settings → General (also persisted in storage/app/platform_branding.json)
XANDER_CONTACT_NAME=
XANDER_CONTACT_EMAIL=
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
